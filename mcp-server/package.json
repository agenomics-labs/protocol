{
  "name": "@agenomics/mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Agenomics Protocol on Solana",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aep-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch",
    "test": "node --import tsx --test test/action-shape.test.ts test/solana-v2.test.ts test/pipeline.test.ts test/handlers-v2-vault.test.ts test/smoke-integration.test.ts test/transport-auth.test.ts test/loadwallet-permission.test.ts test/idl-typed-decode.test.ts test/result-util.test.ts test/logger.test.ts"
  },
  "keywords": [
    "mcp",
    "solana",
    "aep",
    "agent",
    "vault",
    "settlement"
  ],
  "author": "Alejandro",
  "license": "UNLICENSED",
  "dependencies": {
    "@agenomics/capability-manifest-validator": "file:../packages/capability-manifest-validator",
    "@agenomics/sas-resolver": "file:../packages/sas-resolver",
    "@coral-xyz/anchor": "^0.31.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana-program/system": "0.12.0",
    "@solana/kit": "6.8.0",
    "@solana/web3.js": "^1.87.0",
    "bs58": "^5.0.0",
    "dotenv": "^16.3.1",
    "ioredis": "5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "diff": ">=8.0.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.9.0",
    "chai": "^6.2.2",
    "ioredis-mock": "^8.9.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
