{
  "name": "@agenomics/mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Agenomics Protocol on Solana",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aep-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "gen:vault-layout": "node --import tsx scripts/gen-vault-layout.ts",
    "prebuild": "npm run gen:vault-layout",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch",
    "lint": "eslint src",
    "pretest": "cd .. && npm -w @agenomics/action-runtime -w @agenomics/capability-manifest-validator -w @agenomics/sas-resolver -w @agenomics/reputation-attestor run build",
    "test": "node --import tsx --test test/action-shape.test.ts test/solana-v2.test.ts test/pipeline.test.ts test/handlers-v2-vault.test.ts test/smoke-integration.test.ts test/transport-auth.test.ts test/transport-rate-limit.test.ts test/loadwallet-permission.test.ts test/idl-typed-decode.test.ts test/result-util.test.ts test/logger.test.ts test/observability.test.ts test/governance.test.ts test/create-vault-bind-proof.test.ts test/find-similar-agents.test.ts test/record-outcome.test.ts test/evo-bridge-resilience.test.ts test/aud-129-evo-roundtrip.integration.test.ts test/idempotency-ttl.test.ts test/transport-origin.test.ts test/vault-layout-drift.test.ts test/preflight-contract.test.ts test/tools/pay-x402-service.test.ts test/tools/schema-snapshot.test.ts test/p2-mcp-adr.test.ts"
  },
  "keywords": [
    "mcp",
    "solana",
    "aep",
    "agent",
    "vault",
    "settlement"
  ],
  "author": "Alejandro",
  "license": "Apache-2.0",
  "dependencies": {
    "@agenomics/action-runtime": "*",
    "@agenomics/capability-manifest-validator": "*",
    "@agenomics/reputation-attestor": "*",
    "@agenomics/sas-resolver": "*",
    "@coinbase/cdp-sdk": "^1.49.0",
    "@coinbase/x402": "^2.1.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana-program/system": "0.12.0",
    "@solana/kit": "6.9.0",
    "@solana/web3.js": "^1.87.0",
    "bs58": "^5.0.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "x402-fetch": "^1.2.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "diff": ">=8.0.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.4",
    "chai": "^6.2.2",
    "ioredis-mock": "^8.9.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
