{
  "name": "@aeap/mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Autonomous Economic Agents Protocol (AEAP) on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aeap-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "solana",
    "aeap",
    "agent",
    "vault",
    "settlement"
  ],
  "author": "Alejandro",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.87.0",
    "bs58": "^5.0.0",
    "dotenv": "^16.3.1"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "diff": ">=8.0.3"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.9.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.2.2"
  }
}
