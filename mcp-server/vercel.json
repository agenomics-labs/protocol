{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd .. && npm ci && npm -w @agenomics/action-runtime -w @agenomics/capability-manifest-validator -w @agenomics/sas-resolver -w @agenomics/mcp-server run build && cd mcp-server && node scripts/bundle-vercel.mjs",
  "outputDirectory": "dist",
  "functions": {
    "api/bundled.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/healthz", "destination": "/api/bundled" },
    { "source": "/", "destination": "/api/bundled" },
    { "source": "/(.*)", "destination": "/api/bundled" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
