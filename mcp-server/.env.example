# AEP MCP Server Environment Configuration

# Solana RPC Endpoint
# Defaults to Devnet: https://api.devnet.solana.com
# Other common endpoints:
#   - Mainnet: https://api.mainnet-beta.solana.com
#   - Testnet: https://api.testnet.solana.com
#   - Local: http://localhost:8899
SOLANA_RPC_URL=https://api.devnet.solana.com

# Path to Solana Keypair (private key file)
# Defaults to: ~/.config/solana/id.json
# Create a keypair:
#   solana-keygen new --outfile ~/.config/solana/id.json
# Or use Solana CLI default:
#   solana-keygen new
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# Optional: Program Addresses (once deployed)
# These would be configured after deploying your on-chain programs
# AGENT_VAULT_PROGRAM_ID=YourVaultProgramIDHere
# AGENT_REGISTRY_PROGRAM_ID=YourRegistryProgramIDHere
# SETTLEMENT_PROTOCOL_PROGRAM_ID=YourSettlementProgramIDHere
