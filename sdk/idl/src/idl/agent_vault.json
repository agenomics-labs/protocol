              "defined": {
                "name": "ReputationStake"
              }
            }
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "manifest_cid",
            "type": {
              "array": [
                "u8",
                64
              ]
            }
          },
          {
            "name": "manifest_hash",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "manifest_signature",
            "type": {
