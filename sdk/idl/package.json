{
  "name": "@agenomics/idl",
  "version": "0.1.0",
  "description": "AEP protocol IDL types and cluster-keyed program IDs for the Agenomics on-chain programs (agent-registry, agent-vault, settlement).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agenomics",
    "aep",
    "solana",
    "anchor",
    "idl",
    "program-ids"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agenomics-labs/protocol.git",
    "directory": "sdk/idl"
  },
  "bugs": {
    "url": "https://github.com/agenomics-labs/protocol/issues"
  },
  "homepage": "https://github.com/agenomics-labs/protocol/tree/main/sdk/idl#readme",
  "license": "Apache-2.0",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
