{
  "name": "@agenomics/client",
  "version": "0.1.0",
  "description": "AEP protocol TypeScript client: AepClient, typed wrappers (AgentRegistryClient, AgentVaultClient, SettlementClient), PDA derivation helpers; re-exports @agenomics/idl.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agenomics",
    "aep",
    "solana",
    "anchor",
    "client",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agenomics-labs/protocol.git",
    "directory": "sdk/client"
  },
  "bugs": {
    "url": "https://github.com/agenomics-labs/protocol/issues"
  },
  "homepage": "https://github.com/agenomics-labs/protocol/tree/main/sdk/client#readme",
  "license": "Apache-2.0",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "codegen": "node codama.config.mjs",
    "codegen:check": "node codama.config.mjs && git diff --exit-code -- src/generated",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@agenomics/idl": "*",
    "@agenomics/reputation-attestor": "*",
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/kit": "6.8.0",
    "@solana/program-client-core": "^6.9.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.4.1",
    "@codama/renderers-core": "^1.0.34",
    "@codama/renderers-js": "^2.2.0",
    "@types/node": "^24.12.4",
    "codama": "^1.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
