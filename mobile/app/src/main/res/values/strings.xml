    <string name="onboarding_title">Reflex</string>
    <string name="onboarding_welcome_heading">Bring your agent online.</string>
    <string name="onboarding_welcome_body">
        Reflex turns your Seeker into the home for an autonomous agent that
        pays for services on your behalf, handshakes with other agents over
        NFC, and posts a verifiable record to Solana. Authorise your Seed
        Vault wallet to bind this agent to your identity.
    </string>
