{
  "name": "aep-anchor-workspace",
  "version": "0.1.0",
  "description": "Agenomics Protocol - Anchor Workspace",
  "main": "target/types/index.ts",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "sdk/idl",
    "sdk/action-runtime",
    "packages/*",
    "sdk/client",
    "mcp-server",
    "src/indexer",
    "src/x402-relay",
    "dashboard"
  ],
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "deploy": "anchor deploy",
    "postinstall": "npm -w @agenomics/idl -w @agenomics/action-runtime -w @agenomics/capability-manifest-validator -w @agenomics/reputation-attestor -w @agenomics/sas-resolver -w @agenomics/client -w @agenomics/mcp-server run build --if-present"
  },
  "dependencies": {
    "@agenomics/capability-manifest-validator": "file:packages/capability-manifest-validator",
    "@agenomics/sas-resolver": "file:packages/sas-resolver",
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@sqds/multisig": "^2.1.4",
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "mocha": "^11.7.5",
    "pg-mem": "3.0.14",
    "ts-mocha": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "axios": "^1.15.2",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.18",
    "serialize-javascript": "^7.0.5",
    "rpc-websockets": {
      "uuid": "^9.0.1"
    },
    "mocha": {
      "serialize-javascript": "^7.0.5",
      "diff": ">=8.0.3"
    },
    "uuid@>=11.0.0 <11.1.1": ">=11.1.1",
    "express-rate-limit": {
      "ip-address": ">=10.1.1"
    }
  }
}
