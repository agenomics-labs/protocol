# Rust
/target/
# Cargo.lock IS committed — Anchor program binary reproducibility
# depends on locked transitive deps. ADR-089 (reproducible-installs)
# and ADR-114 (Dependabot) both assume the lockfile is in version
# control. Tier-2 dep sweep (2026-04-26) restored that assumption.
**/*.rs.bk

# Anchor
.anchor/
.env
test-ledger/

# Node
node_modules/
dist/
*.log
yarn.lock
# package-lock.json IS committed (ADR-089 — reproducible installs).
# The unified root lockfile governs every workspace member; per-workspace
# lockfiles MUST NOT be committed.

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Compiled binaries
*.so
*.dylib
*.dll
*.exe

# Testing
.mocha
.nyc_output
coverage/
aep-events.db*
aeap-events.db*

# ADR-089: only root /package-lock.json is canonical; per-workspace
# lockfiles MUST NOT be committed (see comment under "Node" above).
**/package-lock.json
!/package-lock.json

# Local AgentDB + ruvector instances (created by claude-flow tooling).
# Per CLAUDE.md "no working files in root" — these are per-machine session
# state from the Claude-Flow / Claude-Code tooling, not protocol artefacts.
# See AUD-041 / PR-AA in docs/audits/REMEDIATION-PLAN.md.
agentdb.rvf
agentdb.rvf.lock
ruvector.db
# Belt-and-suspenders: any future *.rvf / *.rvf.lock at the repo root.
# Leading slash scopes the pattern to the root only — subdirectories that
# legitimately need .rvf files (if any are introduced later) are unaffected.
/*.rvf
/*.rvf.lock

# Claude Code runtime artifacts
.claude-flow/
.claude/local/
.claude/worktrees/
# Per-user permission cache — collects ad-hoc Bash/Read approvals
# during interactive sessions. Project-level settings live in
# `.claude/settings.json` (tracked); .local.json is intentionally
# personal.
.claude/settings.local.json
.swarm/

# Build artifacts
target/
dist/
build/
*.rlib

# Local signer keypairs — NEVER commit
.keys/

# Operational logs — emergency-suspend-credential.ts and friends write
# JSON audit trails here (tx sigs + auditor pubkeys for in-flight
# ceremonies). Must not be committed. See ADR-081 §5.
logs/

# Transparency-log staging area (ADR-063 §7) — until the publisher worker
# is live (ADR-063 "Pending items before Accept" #4), the local staging
# files are scratch artifacts and must not be committed accidentally.
governance/attestation-log/

# Vercel CLI link metadata (per-machine, contains org/project IDs)
.vercel/

# Local Claude Code session scaffolding (per-machine, not shared)
.claude/agents/dual-mode/
.claude/agents/hive-mind/
.claude/helpers/*.cjs
.claude/helpers/*.mjs
.claude/statusline.mjs
.claude/statusline.sh
.claude/scheduled_tasks.lock
.claude/session-env/
.claude/tasks/
