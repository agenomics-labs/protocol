# Rust
/target/
Cargo.lock
**/*.rs.bk

# Anchor
.anchor/
.env
test-ledger/

# Node
node_modules/
dist/
*.log
yarn.lock
# package-lock.json IS committed (ADR-089 — reproducible installs).
# The unified root lockfile governs every workspace member; per-workspace
# lockfiles MUST NOT be committed.

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Compiled binaries
*.so
*.dylib
*.dll
*.exe

# Testing
.mocha
.nyc_output
coverage/
aep-events.db*

# Local AgentDB + ruvector instances (created by claude-flow tooling)
agentdb.rvf
agentdb.rvf.lock
ruvector.db

# Claude Code runtime artifacts
.claude-flow/
.claude/local/
.swarm/

# Build artifacts
target/
dist/
build/
*.rlib

# Local signer keypairs — NEVER commit
.keys/

# Operational logs — emergency-suspend-credential.ts and friends write
# JSON audit trails here (tx sigs + auditor pubkeys for in-flight
# ceremonies). Must not be committed. See ADR-081 §5.
logs/

# Transparency-log staging area (ADR-063 §7) — until the publisher worker
# is live (ADR-063 "Pending items before Accept" #4), the local staging
# files are scratch artifacts and must not be committed accidentally.
governance/attestation-log/
