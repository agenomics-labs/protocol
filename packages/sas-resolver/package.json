{
  "name": "@agenomics/sas-resolver",
  "version": "0.1.0",
  "description": "ADR-064 reference resolver for ADR-061 manifest-referenced SAS attestations. Off-chain only; dereferences manifest.agent.owner_attestation, parses AEP_AGENT_REPUTATION_v1, and surfaces merge helpers for registry + SAS UX.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cache-redis": {
      "types": "./dist/cache-redis.d.ts",
      "import": "./dist/cache-redis.js"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agenomics",
    "aep",
    "solana",
    "sas",
    "solana-attestation-service",
    "reputation",
    "resolver"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agenomics-labs/protocol.git",
    "directory": "packages/sas-resolver"
  },
  "bugs": {
    "url": "https://github.com/agenomics-labs/protocol/issues"
  },
  "homepage": "https://github.com/agenomics-labs/protocol/tree/main/packages/sas-resolver#readme",
  "license": "Apache-2.0",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "node --import tsx --test test/resolver.test.ts test/schema.test.ts test/merge.test.ts test/cache.test.ts test/agenomics-reputation.test.ts"
  },
  "dependencies": {
    "@agenomics/action-runtime": "*",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@agenomics/reputation-attestor": "*",
    "@solana/kit": "^6.9.0",
    "ioredis": "^5.10.1"
  },
  "peerDependenciesMeta": {
    "@agenomics/reputation-attestor": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/kit": "^6.9.0",
    "@types/node": "^20.9.0",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  },
  "optionalDependencies": {
    "ioredis": "^5.10.1"
  }
}
