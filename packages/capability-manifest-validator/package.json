{
  "name": "@agenomics/capability-manifest-validator",
  "version": "0.1.0",
  "description": "ADR-060 reference validator for AEP capability manifests. Validates schema, RFC-8785 canonical-JSON hash, and Ed25519 signature.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "src/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/validate.test.ts test/golden-canonical.test.ts"
  },
  "keywords": [
    "aep",
    "solana",
    "capability",
    "manifest",
    "ed25519",
    "rfc-8785"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@agenomics/action-runtime": "*",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "canonicalize": "2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
