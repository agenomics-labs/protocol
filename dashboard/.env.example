# Solana RPC endpoint (default: devnet)
VITE_RPC_URL=https://api.devnet.solana.com

# Indexer API endpoint (default: localhost:3100)
# Start the indexer with: cd src/indexer && npm start
VITE_INDEXER_URL=http://localhost:3100

# Optional: monitor a specific vault's balance (base58 pubkey)
# VITE_MONITORED_VAULT=
